# =============================================================================
# CLOUDGUARD FRONTEND — ENVIRONMENT VARIABLES TEMPLATE
# =============================================================================
# Copy this file to .env.local for local development:
#
#   cp .env.example .env.local
#
# For production deployments, configure these in your hosting platform's
# environment variable dashboard (Vercel, Netlify, Railway, Docker, etc.)
# Do NOT commit .env.local or any file with real credentials.
# =============================================================================


# -----------------------------------------------------------------------------
# NEXT_PUBLIC_API_BASE
# Base URL of the cloud-security-copilot FastAPI backend.
# All REST calls (/api/score/*, /api/findings/*, /api/chat/) go here.
#
# Examples:
#   Local:      http://localhost:8000
#   Docker:     http://backend:8000
#   Production: https://api.yourcloudguard.com
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_BASE=http://localhost:8000


# -----------------------------------------------------------------------------
# NEXT_PUBLIC_WS_URL
# Full WebSocket URL for the sovereign War Room stream.
# Used by useSovereignStream.js for live J-Score / topology / narrative events.
#
# Examples:
#   Local:      ws://localhost:8000/ws/war-room
#   Production: wss://api.yourcloudguard.com/ws/war-room
#   (always use wss:// when your backend is behind HTTPS / TLS termination)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/war-room
